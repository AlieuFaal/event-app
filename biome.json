{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules/**/*",
      "!**/.expo/**/*",
      "!**/ios/**/*",
      "!**/android/**/*",
      "!**/static/**/*",
      "!**/migrations/**/*",
      "!**/dist/**/*",
      "!**/build/**/*",
      "!**/infra/**/*",
      "!**/.vinxi/**/*",
      "!**/.nitro/**/*",
      "!**/.output/**/*",
      "!**/.claude/**/*",
      "!**/.obsidian/**/*",
      "!**/.actions/**/*",
      "!**/drizzle/**/*",
      "!**/coverage/**/*",
      "!**/routeTree.gen.ts",
      "!**/*.html"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn"
      },
      "nursery": {
        "useSortedClasses": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noExplicitAny": "on",
        "noArrayIndexKey": "warn"
      }
    }
  }
}
